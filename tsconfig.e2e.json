/* Type-checks the Playwright end-to-end specs and config (Playwright itself
   only strips types, so without this project the e2e code is never checked). */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/e2e",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["e2e/**/*.ts", "playwright.config.ts"]
}
